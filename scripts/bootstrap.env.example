# Copy this file to:
#   .local/bootstrap/bootstrap.env
# and replace placeholder values before running bootstrap or install helpers.

# Optional override for the secure project-local secret directory.
# BOOTSTRAP_SECURE_DIR="/absolute/path/to/bootstrap/.local/bootstrap"

# Optional override for the env file path itself.
# BOOTSTRAP_ENV_FILE="/absolute/path/to/bootstrap/.local/bootstrap/bootstrap.env"

# ---------- Arch install / manual install ----------

# Required: target disk for installation.
BOOTSTRAP_INSTALL_DISK="/dev/<target-disk>"

# Required: installed hostname and primary user.
BOOTSTRAP_INSTALL_HOSTNAME="<hostname>"
BOOTSTRAP_INSTALL_USERNAME="<username>"

# Optional non-secret install settings.
BOOTSTRAP_INSTALL_TIMEZONE="UTC"
BOOTSTRAP_INSTALL_LOCALE="en_US.UTF-8"
BOOTSTRAP_INSTALL_KEYBOARD_LAYOUT="us"

# Required local secret files for the install flow.
BOOTSTRAP_SSH_PUBLIC_KEY_FILE="${BOOTSTRAP_SECURE_DIR}/archinstall/authorized_key.pub"
BOOTSTRAP_ROOT_PASSWORD_FILE="${BOOTSTRAP_SECURE_DIR}/archinstall/root-password"
BOOTSTRAP_USER_PASSWORD_FILE="${BOOTSTRAP_SECURE_DIR}/archinstall/user-password"

# Optional direct env secrets if you prefer env over files.
# BOOTSTRAP_INSTALL_ROOT_PASSWORD="<set-locally>"
# BOOTSTRAP_INSTALL_USER_PASSWORD="<set-locally>"

# Optional local outputs for rendered archinstall JSON.
# BOOTSTRAP_ARCHINSTALL_CONFIG_FILE="${BOOTSTRAP_SECURE_DIR}/archinstall/archinstall-config.json"
# BOOTSTRAP_ARCHINSTALL_CREDS_FILE="${BOOTSTRAP_SECURE_DIR}/archinstall/archinstall-creds.json"

# ---------- Vault / sudo ----------

# Preferred: GPG-encrypted local secret for Ansible vault creation/decryption
# and bootstrap sudo operations.
BOOTSTRAP_VAULT_PASSWORD_GPG_FILE="${BOOTSTRAP_SECURE_DIR}/vault-pass.gpg"

# Optional: pin a specific local GPG recipient. If omitted, setup-vault-pass.sh
# uses the first available local secret key.
# BOOTSTRAP_VAULT_GPG_RECIPIENT="<gpg-fingerprint-or-email>"

# Optional direct env secret instead of a file.
# BOOTSTRAP_VAULT_PASSWORD="<set-locally>"

# Optional plaintext compatibility fallback. Keep unset in the normal secure
# model; use only for temporary migration if a GPG-backed secret is impossible.
# BOOTSTRAP_VAULT_PASSWORD_FILE="${BOOTSTRAP_SECURE_DIR}/vault-pass"

# Optional dedicated sudo password source if it differs from vault password.
# If omitted, scripts fall back to BOOTSTRAP_VAULT_PASSWORD / _GPG_FILE.
# BOOTSTRAP_SUDO_PASSWORD_GPG_FILE="${BOOTSTRAP_SECURE_DIR}/sudo-password.gpg"
# BOOTSTRAP_SUDO_PASSWORD_FILE="${BOOTSTRAP_SECURE_DIR}/sudo-password"
# BOOTSTRAP_SUDO_PASSWORD="<set-locally>"
