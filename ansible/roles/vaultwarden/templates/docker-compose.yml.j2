# {{ ansible_managed }}
services:
  vaultwarden:
    image: vaultwarden/server:latest
    container_name: vaultwarden
    restart: unless-stopped
    environment:
      DOMAIN: "https://{{ vaultwarden_domain }}"
      SIGNUPS_ALLOWED: "{{ vaultwarden_signups_allowed | string | lower }}"
{% if vaultwarden_admin_enabled and (_vaultwarden_admin_token is defined or vaultwarden_admin_token) %}
      ADMIN_TOKEN: "{{ _vaultwarden_admin_token | default(vaultwarden_admin_token) }}"
{% endif %}
      ROCKET_PORT: "80"
      SENDS_ALLOWED: "true"
      EMERGENCY_ACCESS_ALLOWED: "true"
      PASSWORD_ITERATIONS: "{{ _vaultwarden_security_merged.password_iterations }}"
      LOGIN_RATELIMIT_MAX_BURST: "{{ _vaultwarden_security_merged.login_ratelimit_max_burst }}"
      LOGIN_RATELIMIT_SECONDS: "{{ _vaultwarden_security_merged.login_ratelimit_seconds }}"
      ADMIN_RATELIMIT_MAX_BURST: "{{ _vaultwarden_security_merged.admin_ratelimit_max_burst }}"
      ADMIN_RATELIMIT_SECONDS: "{{ _vaultwarden_security_merged.admin_ratelimit_seconds }}"
    volumes:
      - "{{ vaultwarden_base_dir }}/data:/data"
    networks:
      - proxy

networks:
  proxy:
    external: true
    name: "{{ vaultwarden_docker_network }}"
