# {{ ansible_managed }}
services:
  vaultwarden:
    image: {{ vaultwarden_docker_image | to_json }}
    container_name: vaultwarden
    restart: unless-stopped
    environment:
      DOMAIN: "https://{{ vaultwarden_domain }}"
      SIGNUPS_ALLOWED: "{{ vaultwarden_signups_allowed | string | lower }}"
{% if vaultwarden_admin_enabled %}
      ADMIN_TOKEN: {{ _vaultwarden_effective_admin_token | replace('$', '$$') | to_json }}
{% endif %}
      ROCKET_PORT: "80"
      SENDS_ALLOWED: "true"
      EMERGENCY_ACCESS_ALLOWED: "true"
      PASSWORD_ITERATIONS: "{{ vaultwarden_security.password_iterations }}"
      LOGIN_RATELIMIT_MAX_BURST: "{{ vaultwarden_security.login_ratelimit_max_burst }}"
      LOGIN_RATELIMIT_SECONDS: "{{ vaultwarden_security.login_ratelimit_seconds }}"
      ADMIN_RATELIMIT_MAX_BURST: "{{ vaultwarden_security.admin_ratelimit_max_burst }}"
      ADMIN_RATELIMIT_SECONDS: "{{ vaultwarden_security.admin_ratelimit_seconds }}"
    volumes:
      - "{{ vaultwarden_base_dir }}/data:/data"
    networks:
      - proxy

networks:
  proxy:
    external: true
    name: "{{ vaultwarden_docker_network }}"
